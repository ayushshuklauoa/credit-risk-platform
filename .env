# API Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_DEBUG=True

# Service URLs
AUTH_SERVICE_URL=http://auth-service:8001
CUSTOMER_SERVICE_URL=http://customer-service:8002
ACCOUNT_SERVICE_URL=http://account-service:8003
CREDIT_SERVICE_URL=http://credit-scoring-service:8004
FRAUD_SERVICE_URL=http://fraud-detection-service:8005
DOCUMENT_SERVICE_URL=http://document-ai-service:8006

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password

# Auth
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# API Keys
API_KEY_SECRET=your-api-key-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=True

# External Services (Placeholders)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# Document AI
DOCUMENT_UPLOAD_MAX_SIZE=10485760
DOCUMENT_UPLOAD_DIR=/app/uploads
